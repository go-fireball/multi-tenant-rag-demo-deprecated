      statusCode: 400,
      statusMessage: "userId is required",
    })
  }

  const tenantId = getTenantId()
  const store = useChatStore()
  const session = store.createSession({
    tenantId,
    userId: body.userId.trim(),
    title: body.title,
  })

  return {
    tenantId,
    session,
  }
})

