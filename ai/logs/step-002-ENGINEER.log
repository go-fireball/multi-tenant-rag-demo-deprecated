+  text-transform: uppercase;
+  letter-spacing: 0.16em;
+  font-size: 0.75rem;
+  color: #7b5b2e;
+}
+
+h1 {
+  margin: 0;
+  font-size: clamp(2.5rem, 5vw, 3.75rem);
+  line-height: 0.95;
+}
+
+.body,
+.tenant {
+  margin: 1.25rem 0 0;
+  font-size: 1rem;
+  line-height: 1.6;
+}
+
+.tenant {
+  font-weight: 600;
+}
+</style>
